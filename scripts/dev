#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
COMPOSE_FILE="${ROOT_DIR}/compose.yaml"
LOCAL_DIR="${ROOT_DIR}/.docker"
LOCAL_ENV="${LOCAL_DIR}/local.env"
ROOT_ENV="${ROOT_DIR}/.env"
ROOT_ENV_EXAMPLE="${ROOT_DIR}/.env.example"
RESOURCE_LABEL="com.class-git-forge.repo=class-git-forge"

usage() {
  cat <<'USAGE'
Usage: scripts/dev <command> [options] [args]

Commands:
  init [--reset]          Generate .docker/local.env and create .env if missing.
  up                     Build missing dev image and start the app detached.
  down                   Stop and remove this worktree's containers/networks.
  status                 Show project, URL, and Compose service status.
  logs                   Stream app logs.
  shell                  Open a shell in the app container.
  run <cmd...>           Run a one-off command in the app container.
  check                  Run compileall and pytest in the app container.
  clean [--force]        Remove this worktree's containers, network, and volumes.
  prune [--force]        Remove unused repo-labelled Docker resources.

Environment:
  CLASS_GIT_FORGE_UID/GID can be edited in .docker/local.env before rebuilding images.
USAGE
}

die() {
  echo "scripts/dev: $*" >&2
  exit 1
}

warn() {
  echo "scripts/dev: $*" >&2
}

hash_text() {
  printf '%s' "$1" | shasum -a 256 | awk '{print substr($1, 1, 8)}'
}

hash_files() {
  shasum -a 256 "$@" | shasum -a 256 | awk '{print substr($1, 1, 12)}'
}

sanitize_label() {
  printf '%s' "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/[^a-z0-9_-]+/-/g; s/^-+//; s/-+$//; s/-+/-/g'
}

branch_label() {
  local label
  label="$(git -C "${ROOT_DIR}" branch --show-current 2>/dev/null || true)"
  if [ -z "${label}" ]; then
    label="head-$(git -C "${ROOT_DIR}" rev-parse --short HEAD 2>/dev/null || printf 'unknown')"
  fi
  label="$(sanitize_label "${label}")"
  if [ -z "${label}" ] || ! printf '%s' "${label}" | grep -Eq '^[a-z0-9]'; then
    label="worktree-${label}"
  fi
  printf '%s' "${label}"
}

project_name() {
  local label path_hash
  label="$(branch_label)"
  path_hash="$(hash_text "${ROOT_DIR}")"
  printf 'class-git-forge-%s-%s' "${label}" "${path_hash}"
}

port_in_use() {
  local port="$1"
  if command -v lsof >/dev/null 2>&1; then
    lsof -nP -iTCP:"${port}" -sTCP:LISTEN >/dev/null 2>&1
    return $?
  fi
  nc -z 127.0.0.1 "${port}" >/dev/null 2>&1
}

first_free_port() {
  local preferred="$1"
  local start="$2"
  local end="$3"
  local port

  if ! port_in_use "${preferred}"; then
    printf '%s' "${preferred}"
    return
  fi

  port="${start}"
  while [ "${port}" -le "${end}" ]; do
    if ! port_in_use "${port}"; then
      printf '%s' "${port}"
      return
    fi
    port=$((port + 1))
  done

  die "no free port found in ${start}-${end}"
}

ensure_root_env() {
  if [ ! -f "${ROOT_ENV}" ] && [ -f "${ROOT_ENV_EXAMPLE}" ]; then
    cp "${ROOT_ENV_EXAMPLE}" "${ROOT_ENV}"
    warn "created .env from .env.example; set GITLAB_URL and GITLAB_TOKEN before real GitLab validation"
  fi

  if [ -f "${ROOT_ENV}" ] && grep -q 'GITLAB_TOKEN=""' "${ROOT_ENV}"; then
    warn ".env has an empty GITLAB_TOKEN; local app and CSV validation work, but GitLab API checks will not authenticate"
  fi
}

write_local_env_values() {
  local compose_project="$1"
  local app_port="$2"
  local uid="$3"
  local gid="$4"
  local app_hash

  app_hash="$(hash_files "${ROOT_DIR}/requirements.txt" "${ROOT_DIR}/docker/dev/app.Dockerfile")"

  cat > "${LOCAL_ENV}" <<EOF
# Generated by scripts/dev. Do not commit.
COMPOSE_PROJECT_NAME=${compose_project}
CLASS_GIT_FORGE_APP_PORT=${app_port}
CLASS_GIT_FORGE_APP_IMAGE=class-git-forge-app-dev:${app_hash}
CLASS_GIT_FORGE_UID=${uid}
CLASS_GIT_FORGE_GID=${gid}
EOF
}

write_local_env() {
  mkdir -p "${LOCAL_DIR}"
  write_local_env_values "$(project_name)" "$(first_free_port 8080 8081 8099)" "10001" "10001"
}

refresh_local_env() {
  if [ ! -f "${LOCAL_ENV}" ]; then
    write_local_env
    return
  fi

  # shellcheck disable=SC1090
  set -a
  source "${LOCAL_ENV}"
  set +a

  if [ -z "${COMPOSE_PROJECT_NAME:-}" ] || [ -z "${CLASS_GIT_FORGE_APP_PORT:-}" ]; then
    write_local_env
    return
  fi

  write_local_env_values \
    "${COMPOSE_PROJECT_NAME}" \
    "${CLASS_GIT_FORGE_APP_PORT}" \
    "${CLASS_GIT_FORGE_UID:-10001}" \
    "${CLASS_GIT_FORGE_GID:-10001}"
}

load_local_env() {
  refresh_local_env

  # shellcheck disable=SC1090
  set -a
  source "${LOCAL_ENV}"
  set +a
}

compose() {
  docker compose --env-file "${LOCAL_ENV}" --project-directory "${ROOT_DIR}" -f "${COMPOSE_FILE}" -p "${COMPOSE_PROJECT_NAME}" "$@"
}

confirm_or_force() {
  local force="$1"
  local prompt="$2"

  if [ "${force}" = "true" ]; then
    return 0
  fi

  printf '%s [y/N] ' "${prompt}" >&2
  read -r answer
  case "${answer}" in
    y|Y|yes|YES) return 0 ;;
    *) die "aborted" ;;
  esac
}

running_project_containers() {
  compose ps --status running -q 2>/dev/null || true
}

ensure_port_available_for_up() {
  local running
  running="$(running_project_containers)"
  if [ -n "${running}" ]; then
    return
  fi

  if port_in_use "${CLASS_GIT_FORGE_APP_PORT}"; then
    die "persisted port is already in use. Stop the conflicting process or run 'scripts/dev init --reset' to generate a new port."
  fi
}

cmd_init() {
  local reset="false"
  if [ "${1:-}" = "--reset" ]; then
    reset="true"
    shift
  fi
  [ "$#" -eq 0 ] || die "init accepts only --reset"

  ensure_root_env
  if [ "${reset}" = "true" ] || [ ! -f "${LOCAL_ENV}" ]; then
    write_local_env
  fi
  load_local_env

  echo "Project: ${COMPOSE_PROJECT_NAME}"
  echo "App: http://127.0.0.1:${CLASS_GIT_FORGE_APP_PORT}"
  echo "Local Docker env: ${LOCAL_ENV}"
}

cmd_up() {
  ensure_root_env
  load_local_env
  ensure_port_available_for_up
  compose up -d --build app
  cmd_status
}

cmd_down() {
  load_local_env
  compose down --remove-orphans
}

cmd_status() {
  load_local_env
  echo "Project: ${COMPOSE_PROJECT_NAME}"
  echo "App: http://127.0.0.1:${CLASS_GIT_FORGE_APP_PORT}"
  echo "Local Docker env: ${LOCAL_ENV}"
  compose ps
}

cmd_logs() {
  load_local_env
  compose logs -f app
}

cmd_shell() {
  load_local_env
  [ "$#" -eq 0 ] || die "shell does not accept arguments"
  compose exec app sh
}

cmd_run() {
  [ "$#" -ge 1 ] || die "run requires a command"
  ensure_root_env
  load_local_env
  compose run --rm app "$@"
}

cmd_check() {
  ensure_root_env
  load_local_env
  compose build app
  compose run --rm app python -m compileall app
  compose run --rm app pytest
}

cmd_clean() {
  local force="false"
  if [ "${1:-}" = "--force" ]; then
    force="true"
    shift
  fi
  [ "$#" -eq 0 ] || die "clean accepts only --force"

  load_local_env
  confirm_or_force "${force}" "Remove containers, networks, and volumes for ${COMPOSE_PROJECT_NAME}?"
  compose down --volumes --remove-orphans
}

cmd_prune() {
  local force="false"
  if [ "${1:-}" = "--force" ]; then
    force="true"
    shift
  fi
  [ "$#" -eq 0 ] || die "prune accepts only --force"

  confirm_or_force "${force}" "Remove unused Docker resources labelled ${RESOURCE_LABEL}?"
  docker container prune --force --filter "label=${RESOURCE_LABEL}"
  docker network prune --force --filter "label=${RESOURCE_LABEL}"
  docker volume prune --force --filter "label=${RESOURCE_LABEL}"
  docker image prune --all --force --filter "label=${RESOURCE_LABEL}"
}

main() {
  local command="${1:-}"
  if [ -z "${command}" ] || [ "${command}" = "-h" ] || [ "${command}" = "--help" ]; then
    usage
    exit 0
  fi
  shift

  case "${command}" in
    init) cmd_init "$@" ;;
    up) cmd_up "$@" ;;
    down) cmd_down "$@" ;;
    status) cmd_status "$@" ;;
    logs) cmd_logs "$@" ;;
    shell) cmd_shell "$@" ;;
    run) cmd_run "$@" ;;
    check) cmd_check "$@" ;;
    clean) cmd_clean "$@" ;;
    prune) cmd_prune "$@" ;;
    *) usage >&2; die "unknown command: ${command}" ;;
  esac
}

main "$@"
